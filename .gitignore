# OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-*

# Build output / coverage — placeholders, expand per language
dist/
build/
out/
coverage/
coverage.out
coverage.xml
*.lcov
.nyc_output/

# Dependency caches — expand per language
node_modules/
__pycache__/
*.py[cod]
.venv/
venv/
.cache/

# Env files (committed examples allowed; real ones never)
.env
.env.local
.env.*.local

# Pre-commit
.pre-commit-cache/

# Obsidian — vault config is committed; personal state is ignored.
# See docs/wiki/obsidian-setup.md for what's pinned and why.
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
.obsidian/cache
.obsidian/cache/**
.obsidian/themes/PLN/

# Plugin runtime state we don't want to ship — add explicit allowlist below
# when you actually want a plugin's config tracked.
# (Linter, Templater, Folder Notes are explicitly committed via git add.)
.obsidian/plugins/*/.gitignore
.obsidian/plugins/*/manifest.json
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
