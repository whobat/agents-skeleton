# EditorConfig is awesome: https://editorconfig.org
# Top-most EditorConfig file.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Tabs for languages where the convention is tabs.
[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

# Wider indents where the community prefers it.
[*.{py,java,kt}]
indent_size = 4

# Markdown allows trailing whitespace as a hard line break.
[*.md]
trim_trailing_whitespace = false

# Windows batch / PowerShell expect CRLF.
[*.{bat,cmd,ps1}]
end_of_line = crlf
