# Normalise line endings so checkouts match across Windows / macOS / Linux.
# Default: let git decide based on file content.
* text=auto

# Source code: always LF in the repo.
*.go        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.py        text eol=lf
*.rb        text eol=lf
*.rs        text eol=lf
*.java      text eol=lf
*.kt        text eol=lf
*.swift     text eol=lf
*.c         text eol=lf
*.h         text eol=lf
*.cpp       text eol=lf
*.hpp       text eol=lf

# Shell scripts MUST be LF — bash on Linux/macOS will not run CRLF scripts.
*.sh        text eol=lf
*.bash      text eol=lf

# Configuration / docs.
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.proto     text eol=lf
*.graphql   text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf

# Windows scripts MUST be CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binaries — never normalise.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.woff      binary
*.woff2     binary
